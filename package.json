{
  "name": "phoneticsweb",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "build:production": "NODE_ENV=production next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:debug": "node --inspect-brk ./node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:unit": "jest --testPathPattern='/__tests__/.*\\.test\\.[jt]sx?$'",
    "test:integration": "jest --testPathPattern='/__tests__/.*\\.integration\\.test\\.[jt]sx?$'",
    "precommit": "npm test -- --passWithNoTests --watchAll=false && npm run lint",
    "check:performance": "node scripts/check-performance.js",
    "check:accessibility": "node scripts/check-accessibility.js",
    "optimize": "npm run lint:fix && npm run check:performance && npm run check:accessibility"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.3.0",
    "@vercel/analytics": "^1.5.0",
    "clsx": "^2.1.1",
    "critters": "^0.0.23",
    "lucide-react": "^0.525.0",
    "next": "15.4.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "^0.34.3",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/testing-library__jest-dom": "^5.14.9",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "15.4.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.0.11",
    "jest": "^30.0.4",
    "jest-axe": "^9.0.0",
    "jest-environment-jsdom": "^30.0.4",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
